# Environment
DATABASE_URL=postgresql://whatsnext:whatsnext@localhost:5433/whatsnext?schema=public
REDIS_URL=redis://localhost:6381
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# OAuth (configure for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Storage
S3_BUCKET=whatsnext-uploads
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPLOAD_DIR=./uploads

# OCR (scanned CVs / images) — https://ocr.space/ocrapi
OCR_SPACE_API_KEY=
# Optional: eng, auto (engine 2/3), lit for Lithuanian if supported
OCR_SPACE_LANGUAGE=eng
# 1, 2 (recommended), or 3
OCR_SPACE_ENGINE=2
# OCR_SPACE_API_URL=https://api.ocr.space/parse/image

API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
WEB_URL=http://localhost:3000
